generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  RENTER
  LANDLORD
  ADMIN
}

enum Kind {
  SALE
  RENT
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum RentStatus {
  ACTIVE
  ENDED
}

enum RentalRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELED
}

enum RentalRequestType {
  RENT_REQUEST
  BUY_REQUEST
}

model User {
  id       String @id @default(nanoid())
  clerkId  String @unique
  username String @unique
  name     String

  phone  String
  email  String  @unique
  about  String
  avatar String?

  role UserRole @default(RENTER)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  listings Listing[] @relation("OwnerListings")

  rents   Rent[]
  reviews Review[]

  savedpost SavedPost[]

  rentalRequestsSent     RentalRequest[] @relation("RentalRequestsSent")
  rentalRequestsReceived RentalRequest[] @relation("RentalRequestsReceived")

  currentRentedListings Listing[] @relation("CurrentRenter")

  @@index([clerkId])
  @@index([role])
}

model Listing {
  id String @id @default(nanoid())

  ownerId String
  owner   User   @relation("OwnerListings", fields: [ownerId], references: [id], onDelete: Cascade)

  photo   String
  title   String
  address String
  price   Int
  kind    Kind   @default(RENT)

  rooms  Int?
  sizeM2 Int?

  lat Float?
  lng Float?

  status   ApprovalStatus @default(PENDING)
  isActive Boolean        @default(true)

  currentRenterId String?
  currentRenter   User?   @relation("CurrentRenter", fields: [currentRenterId], references: [id], onDelete: SetNull)

  currentRentId String? @unique
  currentRent   Rent?   @relation("CurrentRent", fields: [currentRentId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rents Rent[] @relation("RentListing")

  reviews        Review[]
  savedpost      SavedPost[]
  rentalRequests RentalRequest[]

  @@index([ownerId])
  @@index([status])
  @@index([isActive])
  @@index([currentRenterId])
  @@index([kind])
}

model SavedPost {
  id String @id @default(nanoid())

  renterId String
  renter   User   @relation(fields: [renterId], references: [id], onDelete: Cascade)

  listingId String
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([renterId, listingId])
  @@index([renterId])
  @@index([listingId])
}

model Rent {
  id String @id @default(nanoid())

  listingId String
  listing   Listing @relation("RentListing", fields: [listingId], references: [id], onDelete: Cascade)

  renterId String
  renter   User   @relation(fields: [renterId], references: [id], onDelete: Cascade)

  status RentStatus @default(ACTIVE)

  startAt DateTime  @default(now())
  endAt   DateTime?

  rentalRequestId String?        @unique
  rentalRequest   RentalRequest? @relation(fields: [rentalRequestId], references: [id], onDelete: SetNull)

  currentForListing Listing? @relation("CurrentRent")

  createdAt DateTime @default(now())

  reviews Review[]

  @@index([listingId])
  @@index([renterId])
  @@index([status])
  @@index([startAt])
}

model Review {
  id String @id @default(nanoid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  listingId String
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  rentId String
  rent   Rent   @relation(fields: [rentId], references: [id], onDelete: Cascade)

  rating  Int
  comment String?

  createdAt DateTime @default(now())

  @@unique([userId, rentId])
  @@index([userId])
  @@index([listingId])
  @@index([rentId])
}

model RentalRequest {
  id String @id @default(nanoid())

  listingId String
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  landlordId String
  landlord   User   @relation("RentalRequestsReceived", fields: [landlordId], references: [id], onDelete: Cascade)

  renterId String
  renter   User   @relation("RentalRequestsSent", fields: [renterId], references: [id], onDelete: Cascade)

  type RentalRequestType @default(RENT_REQUEST)

  message        String
  phone          String?
  moveInDate     DateTime?
  durationMonths Int?

  status RentalRequestStatus @default(PENDING)

  decidedAt    DateTime?
  decisionNote String?

  rent Rent?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([listingId])
  @@index([landlordId])
  @@index([renterId])
  @@index([status])
  @@index([createdAt])
  @@index([type])
}
